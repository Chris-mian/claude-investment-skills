# ─────────────────────────────────────────────────────────────────────────────
# price-alert .env template — DO NOT commit your real values
#
# This file is the TEMPLATE. Copy it to `.env` in the same directory, then
# fill in your real values:
#
#     cp .env.example .env
#     # edit .env in your editor, paste your real token + chat_id
#
# `.env` is gitignored at the repo root so your secrets won't be committed.
# This `.env.example` file IS committed so future users know what to fill in.
# ─────────────────────────────────────────────────────────────────────────────

# Telegram bot token from @BotFather (Step 1 in SETUP.md)
# Format: numeric_id:alphanumeric_string
# Example: 7234567890:AAH-xxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_BOT_TOKEN=PASTE_YOUR_TOKEN_HERE

# Your Telegram chat_id from /getUpdates (Step 2 in SETUP.md)
# Private chats: positive integer (e.g. 987654321)
# Group chats:   negative integer (e.g. -1001234567890)
TELEGRAM_CHAT_ID=PASTE_YOUR_CHAT_ID_HERE

# ─────────────────────────────────────────────────────────────────────────────
# IMPORTANT: GitHub Actions does NOT read this .env file.
# For automated cron runs, you MUST also add these as GitHub repo secrets:
#   Settings → Secrets and variables → Actions → New repository secret
#
# This .env file is only for LOCAL testing/development, e.g.:
#   python price-alert/scripts/check_alerts.py
# ─────────────────────────────────────────────────────────────────────────────
